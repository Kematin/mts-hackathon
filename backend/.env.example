# App settings
DEBUG=True
API_HOST=localhost
API_PORT=8000

# AI settings
# При локальном запуске: http://localhost:11434
# В Docker: http://ollama:11434
OLLAMA_URL=http://localhost:11434

# Для разработки: qwen3.5:2b (быстрее, меньше VRAM)
# Для продакшена: qwen3.5:9b (лучше качество кода)
OLLAMA_MODEL=qwen3.5:2b

# При локальном запуске: http://localhost:8081/validate
# В Docker: http://lua-sandbox:8081/validate
VALIDATOR_URL=http://localhost:8081/validate

MAX_RETRIES=2
